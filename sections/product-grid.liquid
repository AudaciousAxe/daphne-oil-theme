{%- assign collection = section.settings.collection -%}
<section class="products-section" data-section-id="{{ section.id }}">
  <div class="products-header">
    <div>
      {%- if section.settings.subtitle != blank -%}
        <p class="about-tag">{{ section.settings.subtitle }}</p>
      {%- endif -%}
      <h2>{{ section.settings.title }}</h2>
    </div>
    {%- if section.settings.show_view_all and collection != blank -%}
      <a href="{{ collection.url }}" class="btn btn--outline">Voir tout</a>
    {%- endif -%}
  </div>
  <div class="products-grid">
    {%- if collection != blank -%}
      {%- for product in collection.products limit: section.settings.products_count -%}
        {% render 'product-card', product: product %}
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..4) -%}
        <div class="product-card">
          <div class="product-card-image">{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
          <h4>Produit exemple {{ i }}</h4>
          <p class="product-card-meta">Bio · 250ml</p>
          <p class="product-card-price">€12,90</p>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Grille produits",
  "class": "products-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "default": "Nos produits",
      "label": "Sous-titre"
    },
    {
      "type": "richtext",
      "id": "title",
      "default": "<p>La gamme <em>Daphne</em></p>",
      "label": "Titre"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Nombre de produits"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Afficher le bouton 'Voir tout'"
    }
  ],
  "presets": [
    {
      "name": "Grille produits"
    }
  ]
}
{% endschema %}
