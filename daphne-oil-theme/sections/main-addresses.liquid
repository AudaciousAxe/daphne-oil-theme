<div class="customer-page" style="max-width:900px;">
  <h1>Mes adresses</h1>
  {%- for address in customer.addresses -%}
    <div style="padding:20px 0;border-bottom:1px solid var(--color-border);">
      <p>{{ address.first_name }} {{ address.last_name }}</p>
      <p style="color:var(--color-text-secondary);">{{ address.address1 }}{%- if address.address2 != blank -%}, {{ address.address2 }}{%- endif -%}<br>{{ address.city }}, {{ address.zip }}<br>{{ address.country }}</p>
    </div>
  {%- endfor -%}
  <a href="/account" class="btn btn--outline" style="margin-top:24px;">← Retour</a>
</div>

{% schema %}
{ "name": "Mes adresses", "settings": [] }
{% endschema %}
