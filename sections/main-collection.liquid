{%- paginate collection.products by section.settings.products_per_page -%}
<div class="collection-page">
  <div class="collection-header">
    <h1>{{ collection.title }}</h1>
    {%- if collection.description != blank -%}<p>{{ collection.description }}</p>{%- endif -%}
  </div>
  {%- if collection.products.size > 0 -%}
    <div class="collection-toolbar">
      <p class="collection-count">{{ collection.products_count }} produit{%- if collection.products_count > 1 -%}s{%- endif -%}</p>
      <div class="collection-sort">
        {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
        <select id="sort-by" aria-label="Trier par">
          {%- for option in collection.sort_options -%}
            <option value="{{ option.value }}" {% if sort_by == option.value %}selected{% endif %}>{{ option.name }}</option>
          {%- endfor -%}
        </select>
      </div>
    </div>
    <div class="products-grid">
      {%- for product in collection.products -%}
        {% render 'product-card', product: product %}
      {%- endfor -%}
    </div>
    {% render 'pagination', paginate: paginate %}
  {%- else -%}
    <div class="cart-empty"><p>Aucun produit dans cette collection.</p><a href="/collections" class="btn btn--primary">Voir les collections</a></div>
  {%- endif -%}
</div>
{%- endpaginate -%}

{% schema %}
{
  "name": "Page collection",
  "settings": [
    { "type": "range", "id": "products_per_page", "min": 8, "max": 24, "step": 4, "default": 12, "label": "Produits par page" }
  ]
}
{% endschema %}
