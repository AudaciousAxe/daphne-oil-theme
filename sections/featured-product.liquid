{%- assign product = section.settings.product -%}
{%- if product != blank -%}
<section class="featured-product" data-section-id="{{ section.id }}">
  <div class="featured-product-inner">
    <div class="featured-product-image">
      {%- if section.settings.badge != blank -%}
        <span class="featured-badge">{{ section.settings.badge }}</span>
      {%- endif -%}
      <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}" loading="lazy">
    </div>
    <div class="featured-product-info">
      {%- if section.settings.subtitle != blank -%}
        <p class="about-tag">{{ section.settings.subtitle }}</p>
      {%- endif -%}
      <h2>{{ section.settings.custom_title | default: product.title }}</h2>
      {%- if section.settings.meta != blank -%}
        <p class="product-info-meta">{{ section.settings.meta }}</p>
      {%- endif -%}
      {%- if settings.show_rating and product.metafields.reviews.rating.value != blank -%}
        <div class="product-rating">
          <span class="stars">★★★★★</span>
          <span>{{ product.metafields.reviews.rating.value }} — {{ product.metafields.reviews.rating_count }} avis</span>
        </div>
      {%- endif -%}
      <div class="featured-product-price">{{ product.price | money }} <small>TTC</small></div>
      {%- if product.compare_at_price > product.price -%}
        <div style="font-size:14px;color:var(--color-text-secondary);text-decoration:line-through;margin-bottom:4px;">{{ product.compare_at_price | money }}</div>
      {%- endif -%}
      <div class="featured-product-unit">{{ section.settings.unit_price }}</div>
      {%- if section.settings.description != blank -%}
        <div class="featured-product-desc">{{ section.settings.description }}</div>
      {%- endif -%}
      {%- if section.blocks.size > 0 -%}
        <div class="product-tags">
          {%- for block in section.blocks -%}
            {%- if block.type == 'tag' -%}
              <span class="product-tag" {{ block.shopify_attributes }}>
                {%- if block.settings.icon == 'leaf' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;color:var(--color-accent)"><path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66L12 14"/><path d="M2 2s7.83 1 11.24 4.41C16.65 9.82 17 14 17 14"/></svg>
                {%- elsif block.settings.icon == 'snowflake' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;color:var(--color-accent)"><line x1="12" y1="2" x2="12" y2="22"/><path d="M20 16l-4-4 4-4"/><path d="M4 8l4 4-4 4"/><path d="M16 4l-4 4-4-4"/><path d="M8 20l4-4 4 4"/></svg>
                {%- elsif block.settings.icon == 'award' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;color:var(--color-accent)"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
                {%- endif -%}
                {{ block.settings.label }}
              </span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
      <a href="{{ product.url }}" class="btn btn--primary btn--full btn--large">Voir le produit</a>
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Produit en avant",
  "class": "featured-product-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Produit"
    },
    {
      "type": "text",
      "id": "subtitle",
      "default": "Daphne · Kalamata",
      "label": "Sous-titre"
    },
    {
      "type": "text",
      "id": "custom_title",
      "label": "Titre personnalisé (optionnel)"
    },
    {
      "type": "text",
      "id": "meta",
      "default": "Variété Koroneiki · Péloponnèse · Certifiée Certisys",
      "label": "Méta-informations"
    },
    {
      "type": "text",
      "id": "badge",
      "default": "Best-seller",
      "label": "Badge (ex: Best-seller)"
    },
    {
      "type": "text",
      "id": "unit_price",
      "default": "€25,20 / litre",
      "label": "Prix au litre"
    },
    {
      "type": "richtext",
      "id": "description",
      "default": "<p>Notre huile d'olive extra vierge biologique est un véritable jus de fruit issu de la variété Koroneiki. Cultivée sur les collines ensoleillées de Kalamata, elle offre un goût fruité et délicat.</p>",
      "label": "Description"
    }
  ],
  "blocks": [
    {
      "type": "tag",
      "name": "Tag produit",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "default": "100% Bio",
          "label": "Texte"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icône",
          "options": [
            { "value": "none", "label": "Aucune" },
            { "value": "leaf", "label": "Feuille (Bio)" },
            { "value": "snowflake", "label": "Flocon (Extraction à froid)" },
            { "value": "award", "label": "Médaille (Primée)" }
          ],
          "default": "leaf"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Produit en avant",
      "blocks": [
        { "type": "tag", "settings": { "label": "100% Bio", "icon": "leaf" } },
        { "type": "tag", "settings": { "label": "Extraction à froid", "icon": "snowflake" } },
        { "type": "tag", "settings": { "label": "Primée", "icon": "award" } }
      ]
    }
  ]
}
{% endschema %}
