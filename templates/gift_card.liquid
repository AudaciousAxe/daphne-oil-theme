{% layout none %}
<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ 'gift_cards.issued.title' | t }} — {{ shop.name }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
  {{ content_for_header }}
  <style>
    :root {
      --color-bg: #0a0a0a;
      --color-text: #f5f0e8;
      --color-accent: #8b9a3a;
      --color-accent-light: #a8b84d;
      --color-border: rgba(255,255,255,0.1);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Outfit', sans-serif;
      background: var(--color-bg);
      color: var(--color-text);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
    }
    .gift-card-wrap {
      max-width: 480px;
      width: 100%;
      text-align: center;
    }
    .gift-card-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 28px;
      font-weight: 600;
      margin-bottom: 32px;
      letter-spacing: 2px;
    }
    .gift-card-logo a { color: inherit; text-decoration: none; }
    .gift-card {
      background: linear-gradient(135deg, #1a1a1a, #0f0f0f);
      border: 1px solid var(--color-border);
      border-radius: 16px;
      padding: 48px 40px;
      margin-bottom: 24px;
    }
    .gift-card-image {
      max-width: 200px;
      margin: 0 auto 24px;
    }
    .gift-card-image img { width: 100%; height: auto; }
    .gift-card h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 20px;
      font-weight: 500;
      margin-bottom: 8px;
      color: var(--color-accent-light);
    }
    .gift-card-amount {
      font-family: 'Cormorant Garamond', serif;
      font-size: 48px;
      font-weight: 600;
      margin: 16px 0;
    }
    .gift-card-code {
      background: rgba(255,255,255,0.05);
      border: 1px dashed var(--color-border);
      border-radius: 8px;
      padding: 16px 24px;
      margin: 24px 0;
      font-size: 20px;
      letter-spacing: 3px;
      font-weight: 600;
      word-break: break-all;
    }
    .gift-card-code.disabled { text-decoration: line-through; opacity: 0.5; }
    .gift-card-expiry {
      font-size: 13px;
      color: rgba(245,240,232,0.5);
      margin-top: 12px;
    }
    .gift-card-qr { margin: 24px auto 0; }
    .gift-card-qr img { margin: 0 auto; }
    .gift-card-actions {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }
    .gift-card-actions a,
    .gift-card-actions button {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 28px;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      border: none;
      cursor: pointer;
      font-family: 'Outfit', sans-serif;
      text-decoration: none;
      transition: all 0.3s ease;
    }
    .btn-primary {
      background: var(--color-accent);
      color: var(--color-bg);
    }
    .btn-primary:hover { background: var(--color-accent-light); }
    .btn-secondary {
      background: transparent;
      color: var(--color-text);
      border: 1px solid var(--color-border);
    }
    .btn-secondary:hover { border-color: var(--color-accent); color: var(--color-accent); }
    @media print {
      .gift-card-actions { display: none; }
      body { background: #fff; color: #000; }
      .gift-card { border-color: #ddd; }
    }
  </style>
</head>
<body>
  <div class="gift-card-wrap">
    <div class="gift-card-logo">
      <a href="{{ shop.url }}">{{ shop.name }}</a>
    </div>

    <div class="gift-card">
      {% if gift_card.image %}
        <div class="gift-card-image">
          <img src="{{ gift_card.image | image_url: width: 400 }}" alt="{{ shop.name }} Gift Card">
        </div>
      {% endif %}

      <h2>{{ 'gift_cards.issued.subtext' | t }}</h2>

      {% if gift_card.initial_value != gift_card.balance %}
        <p class="gift-card-amount">{{ gift_card.balance | money }}</p>
      {% else %}
        <p class="gift-card-amount">{{ gift_card.initial_value | money }}</p>
      {% endif %}

      <div class="gift-card-code{% if gift_card.expired or gift_card.enabled == false %} disabled{% endif %}" id="gift-card-code">
        {{ gift_card.code | format_code }}
      </div>

      {% if gift_card.expired %}
        <p class="gift-card-expiry">{{ 'gift_cards.issued.expired' | t }}</p>
      {% elsif gift_card.expires_on %}
        <p class="gift-card-expiry">{{ 'gift_cards.issued.expiration_date' | t: expires_on: gift_card.expires_on | date: "%d/%m/%Y" }}</p>
      {% endif %}

      <div class="gift-card-qr">
        {{ gift_card.qr_code }}
      </div>
    </div>

    <div class="gift-card-actions">
      <a href="{{ shop.url }}" class="btn-primary">{{ 'gift_cards.issued.shop_link' | t }}</a>
      <button class="btn-secondary" onclick="window.print()">{{ 'gift_cards.issued.print' | t }}</button>
    </div>
  </div>
</body>
</html>
