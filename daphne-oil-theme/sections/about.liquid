<section class="about-section" data-section-id="{{ section.id }}">
  <div class="about-image">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 1000 }}" alt="{{ section.settings.title | escape }}" loading="lazy">
    {%- else -%}
      {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>
  <div class="about-content">
    {%- if section.settings.subtitle != blank -%}
      <p class="about-tag">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="about-title">{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <div class="about-text">{{ section.settings.text }}</div>
    {%- endif -%}
    {%- if section.settings.text_2 != blank -%}
      <div class="about-text">{{ section.settings.text_2 }}</div>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <div class="about-stats">
        {%- for block in section.blocks -%}
          <div class="about-stat" {{ block.shopify_attributes }}>
            <h3>{{ block.settings.value }}</h3>
            <p>{{ block.settings.label }}</p>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "À propos / Histoire",
  "class": "about-section-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "default": "Notre héritage",
      "label": "Sous-titre"
    },
    {
      "type": "richtext",
      "id": "title",
      "default": "<p>Nous créons la meilleure huile d'olive <em>bio</em></p>",
      "label": "Titre"
    },
    {
      "type": "richtext",
      "id": "text",
      "default": "<p>Climat, soleil et harmonie forment un équilibre parfait. Sur les collines ensoleillées de Kalamata, nous cultivons la variété Koroneiki pour offrir une huile biologique d'une qualité exceptionnelle.</p>",
      "label": "Texte paragraphe 1"
    },
    {
      "type": "richtext",
      "id": "text_2",
      "default": "<p>Notre exploitation familiale, située dans les villages d'Asprochorion et Laïka, perpétue un savoir-faire transmis de génération en génération.</p>",
      "label": "Texte paragraphe 2"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistique",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "default": "1854",
          "label": "Valeur"
        },
        {
          "type": "text",
          "id": "label",
          "default": "Année de fondation",
          "label": "Label"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "À propos / Histoire",
      "blocks": [
        { "type": "stat", "settings": { "value": "1854", "label": "Année de fondation" } },
        { "type": "stat", "settings": { "value": "170+", "label": "Ans d'expérience" } },
        { "type": "stat", "settings": { "value": "100%", "label": "Biologique" } }
      ]
    }
  ]
}
{% endschema %}
