<div class="customer-page" style="max-width:900px;">
  <h1>Mon compte</h1>
  <p style="margin-bottom:32px;color:var(--color-text-secondary);">{{ customer.name }} · {{ customer.email }}</p>
  <h2 style="font-size:22px;margin-bottom:20px;">Historique des commandes</h2>
  {%- if customer.orders.size > 0 -%}
    <table class="cart-table">
      <thead><tr><th>Commande</th><th>Date</th><th>Statut</th><th>Total</th></tr></thead>
      <tbody>
        {%- for order in customer.orders -%}
          <tr>
            <td><a href="{{ order.customer_url }}" style="color:var(--color-accent-light);text-decoration:underline;">{{ order.name }}</a></td>
            <td>{{ order.created_at | date: '%d/%m/%Y' }}</td>
            <td>{{ order.financial_status_label }}</td>
            <td>{{ order.total_price | money }}</td>
          </tr>
        {%- endfor -%}
      </tbody>
    </table>
  {%- else -%}
    <p style="color:var(--color-text-secondary);">Aucune commande pour le moment.</p>
  {%- endif -%}
  <div style="margin-top:40px;"><a href="/account/logout" class="btn btn--outline">Se déconnecter</a></div>
</div>

{% schema %}
{ "name": "Mon compte", "settings": [] }
{% endschema %}
