{%- if section.blocks.size > 0 -%}
<div class="announcement-bar" role="region" aria-label="Annonces">
  {%- for block in section.blocks -%}
    <div class="announcement-item" {{ block.shopify_attributes }}>
      {%- if block.settings.icon == 'shipping' -%}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      {%- elsif block.settings.icon == 'leaf' -%}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66L12 14"/><path d="M2 2s7.83 1 11.24 4.41C16.65 9.82 17 14 17 14"/></svg>
      {%- elsif block.settings.icon == 'clock' -%}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
      {%- elsif block.settings.icon == 'star' -%}
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      {%- elsif block.settings.icon == 'shield' -%}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      {%- endif -%}
      {%- if block.settings.link != blank -%}
        <a href="{{ block.settings.link }}">{{ block.settings.text }}</a>
      {%- else -%}
        <span>{{ block.settings.text }}</span>
      {%- endif -%}
    </div>
  {%- endfor -%}
</div>
{%- endif -%}

{% schema %}
{
  "name": "Bandeau d'annonces",
  "class": "announcement-bar-section",
  "max_blocks": 5,
  "settings": [],
  "blocks": [
    {
      "type": "announcement",
      "name": "Annonce",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texte",
          "default": "Livraison gratuite dès 49€"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien (optionnel)"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icône",
          "options": [
            { "value": "none", "label": "Aucune" },
            { "value": "shipping", "label": "Livraison" },
            { "value": "leaf", "label": "Bio / Feuille" },
            { "value": "clock", "label": "Horloge" },
            { "value": "star", "label": "Étoile" },
            { "value": "shield", "label": "Bouclier" }
          ],
          "default": "shipping"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bandeau d'annonces",
      "blocks": [
        { "type": "announcement", "settings": { "text": "Livraison gratuite dès 49€", "icon": "shipping" } },
        { "type": "announcement", "settings": { "text": "Bio certifiée Certisys", "icon": "leaf" } },
        { "type": "announcement", "settings": { "text": "Expédition 24-48h", "icon": "clock" } }
      ]
    }
  ]
}
{% endschema %}
