<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
  <style>
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      text-align: center;
    }
    .password-page {
      max-width: 480px;
      padding: 40px 20px;
    }
    .password-logo {
      font-family: var(--font-heading);
      font-size: 32px;
      font-weight: 600;
      letter-spacing: 2px;
      margin-bottom: 32px;
    }
    .password-logo a { color: inherit; text-decoration: none; }
    .password-message {
      font-size: 14px;
      color: var(--color-text-secondary);
      margin-bottom: 32px;
      line-height: 1.7;
    }
    .password-form { margin-bottom: 24px; }
    .password-form input[type="password"] {
      width: 100%;
      padding: 14px 20px;
      background: rgba(255,255,255,0.05);
      border: 1px solid var(--color-border);
      color: var(--color-text);
      font-size: 14px;
      margin-bottom: 12px;
    }
    .password-login-link {
      font-size: 13px;
      color: var(--color-accent);
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="password-page">
    <div class="password-logo">
      <a href="/">{{ shop.name }}</a>
    </div>
    {{ content_for_layout }}
  </div>
</body>
</html>
