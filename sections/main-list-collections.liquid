<div class="list-collections-page">
  <h1>{{ 'collections.title' | t | default: 'Nos collections' }}</h1>
  <div class="collections-grid">
    {%- for collection in collections -%}
      {%- unless collection.handle == 'all' -%}
        <a href="{{ collection.url }}" class="collection-card">
          {%- if collection.image -%}
            <img src="{{ collection.image | image_url: width: 800 }}" alt="{{ collection.title | escape }}" loading="lazy">
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          <div class="collection-card-overlay">
            <h3>{{ collection.title }}</h3>
            <p>{{ collection.products_count }} produit{%- if collection.products_count > 1 -%}s{%- endif -%}</p>
          </div>
        </a>
      {%- endunless -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{ "name": "Liste collections", "settings": [] }
{% endschema %}
