<div class="customer-page">
  <h1>Activer votre compte</h1>
  {% form 'activate_customer_password' %}
    <div class="customer-form">
      <label for="password">Mot de passe</label>
      <input type="password" id="password" name="customer[password]" required>
      <label for="password-confirm">Confirmer</label>
      <input type="password" id="password-confirm" name="customer[password_confirmation]" required>
      <button type="submit" class="btn btn--primary btn--full">Activer</button>
    </div>
  {% endform %}
</div>

{% schema %}
{ "name": "Activer compte", "settings": [] }
{% endschema %}
