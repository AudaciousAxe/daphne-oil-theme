<footer class="site-footer" data-section-id="{{ section.id }}">
  <div class="footer-top">
    <div class="footer-brand">
      {%- if settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" style="height: {{ settings.logo_width }}px;">
      {%- endif -%}
      {%- if section.settings.footer_text != blank -%}
        <p>{{ section.settings.footer_text }}</p>
      {%- endif -%}
    </div>
    {%- for block in section.blocks -%}
      {%- if block.type == 'menu' -%}
        <div class="footer-col" {{ block.shopify_attributes }}>
          <h4>{{ block.settings.title }}</h4>
          {%- if block.settings.menu != blank -%}
            {%- for link in block.settings.menu.links -%}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {%- endfor -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
  <div class="footer-bottom">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Tous droits réservés.</p>
    <div class="footer-social">
      {%- if settings.social_facebook != blank -%}
        <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
        </a>
      {%- endif -%}
      {%- if settings.social_instagram != blank -%}
        <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
        </a>
      {%- endif -%}
      {%- if settings.social_twitter != blank -%}
        <a href="{{ settings.social_twitter }}" target="_blank" rel="noopener" aria-label="X / Twitter">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      {%- endif -%}
      {%- if settings.social_youtube != blank -%}
        <a href="{{ settings.social_youtube }}" target="_blank" rel="noopener" aria-label="YouTube">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Pied de page",
  "class": "footer-section",
  "settings": [
    {
      "type": "textarea",
      "id": "footer_text",
      "default": "Huile d'olive bio extra vierge certifiée Certisys, cultivée à Kalamata depuis 1854.",
      "label": "Texte de description"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Colonne menu",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Boutique",
          "label": "Titre de colonne"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Pied de page",
      "blocks": [
        { "type": "menu", "settings": { "title": "Boutique" } },
        { "type": "menu", "settings": { "title": "Daphne" } },
        { "type": "menu", "settings": { "title": "Informations" } }
      ]
    }
  ]
}
{% endschema %}
