<section class="terroir-section" data-section-id="{{ section.id }}">
  <div class="terroir-bg">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 2000 }}" alt="{{ section.settings.title | strip_html | escape }}" loading="lazy">
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>
  <div class="terroir-overlay"></div>
  <div class="terroir-content">
    {%- if section.settings.subtitle != blank -%}
      <p class="about-tag" style="color:var(--color-accent-light)">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2>{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <p>{{ section.settings.text }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="btn btn--primary">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Terroir (image plein écran)",
  "class": "terroir-section-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image de fond"
    },
    {
      "type": "text",
      "id": "subtitle",
      "default": "Le terroir",
      "label": "Sous-titre"
    },
    {
      "type": "richtext",
      "id": "title",
      "default": "<p>Le Péloponnèse,<br>berceau de <em>l'olivier</em></p>",
      "label": "Titre"
    },
    {
      "type": "textarea",
      "id": "text",
      "default": "Nous sommes une petite exploitation familiale d'huile d'olive extra vierge biologique olive dans les villages d'Asprochorion et Laïka. Daphne Oil met son expérience et son savoir-faire dans la culture des olives afin de nous offrir des produits d'exception.",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "Découvrir la culture",
      "label": "Texte du bouton"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien du bouton"
    }
  ],
  "presets": [
    {
      "name": "Terroir (image plein écran)"
    }
  ]
}
{% endschema %}
