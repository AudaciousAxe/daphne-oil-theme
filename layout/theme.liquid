<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>
    {%- if page_title -%}
      {{ page_title }}
      {%- if current_tags %} &ndash; {{ current_tags | join: ', ' }}{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    {%- else -%}
      {{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {% render 'meta-tags' %}

  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://cdn.shopify.com">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">

  {{ 'base.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}

  <style>
    :root {
      --color-bg: {{ settings.color_bg }};
      --color-bg-secondary: {{ settings.color_bg_secondary }};
      --color-text: {{ settings.color_text }};
      --color-text-secondary: {{ settings.color_text_secondary }};
      --color-accent: {{ settings.color_accent }};
      --color-accent-light: {{ settings.color_accent_light }};
      --color-accent-bg: {{ settings.color_accent_bg }};
      --color-border: {{ settings.color_border }};
      --color-white: #ffffff;
      --font-heading: '{{ settings.font_heading }}', 'Cormorant Garamond', serif;
      --font-body: '{{ settings.font_body }}', 'Outfit', sans-serif;
      --max-width: 1400px;
      --header-height: 80px;
    }
  </style>

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <script>document.documentElement.className = document.documentElement.className.replace('no-js', 'js');</script>
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">
  <a class="skip-to-content" href="#main">{{ 'general.skip_to_content' | t }}</a>

  {% sections 'header-group' %}

  <main id="main" role="main">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
