<section class="section-padding" data-section-id="{{ section.id }}" style="max-width:{{ section.settings.max_width }}px; margin:0 auto; padding-left:60px; padding-right:60px;">
  {%- if section.settings.subtitle != blank -%}
    <p class="about-tag {% if section.settings.align == 'center' %}text-center{% endif %}">{{ section.settings.subtitle }}</p>
  {%- endif -%}
  {%- if section.settings.title != blank -%}
    <h2 class="about-title {% if section.settings.align == 'center' %}text-center{% endif %}" style="margin-bottom:24px;">{{ section.settings.title }}</h2>
  {%- endif -%}
  {%- if section.settings.text != blank -%}
    <div class="rte {% if section.settings.align == 'center' %}text-center{% endif %}">{{ section.settings.text }}</div>
  {%- endif -%}
  {%- if section.settings.button_label != blank -%}
    <div style="margin-top:32px;{% if section.settings.align == 'center' %}text-align:center{% endif %}">
      <a href="{{ section.settings.button_link }}" class="btn btn--primary">{{ section.settings.button_label }}</a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Texte enrichi",
  "settings": [
    { "type": "text", "id": "subtitle", "label": "Sous-titre" },
    { "type": "richtext", "id": "title", "label": "Titre" },
    { "type": "richtext", "id": "text", "label": "Contenu" },
    { "type": "text", "id": "button_label", "label": "Bouton (optionnel)" },
    { "type": "url", "id": "button_link", "label": "Lien du bouton" },
    { "type": "select", "id": "align", "options": [{"value":"left","label":"Gauche"},{"value":"center","label":"Centre"}], "default": "left", "label": "Alignement" },
    { "type": "range", "id": "max_width", "min": 600, "max": 1400, "step": 100, "default": 800, "unit": "px", "label": "Largeur max" }
  ],
  "presets": [{ "name": "Texte enrichi" }]
}
{% endschema %}
