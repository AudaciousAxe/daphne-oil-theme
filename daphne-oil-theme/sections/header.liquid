<header class="site-header" data-section-id="{{ section.id }}">
  <div class="header-inner">
    <div class="header-logo">
      <a href="/" aria-label="{{ shop.name }}">
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" style="height: {{ settings.logo_width }}px; width: auto;">
        {%- else -%}
          <span>{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <nav class="header-nav" role="navigation">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    <div class="header-actions">
      <a href="/cart" class="header-cart" aria-label="Panier">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <span class="cart-count" data-count="{{ cart.item_count }}">{{ cart.item_count }}</span>
      </a>
      <div class="hamburger" id="hamburger" aria-label="Menu" role="button" tabindex="0">
        <span></span><span></span><span></span>
      </div>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu">
    {%- for link in section.settings.menu.links -%}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {%- endfor -%}
    <a href="/cart">Panier ({{ cart.item_count }})</a>
  </div>
</header>

{% schema %}
{
  "name": "En-tête",
  "class": "header-section",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu de navigation"
    }
  ]
}
{% endschema %}
