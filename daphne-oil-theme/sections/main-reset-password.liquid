<div class="customer-page">
  <h1>Réinitialiser le mot de passe</h1>
  {% form 'reset_customer_password' %}
    <div class="customer-form">
      <label for="password">Nouveau mot de passe</label>
      <input type="password" id="password" name="customer[password]" required>
      <label for="password-confirm">Confirmer</label>
      <input type="password" id="password-confirm" name="customer[password_confirmation]" required>
      <button type="submit" class="btn btn--primary btn--full">Enregistrer</button>
    </div>
  {% endform %}
</div>

{% schema %}
{ "name": "Nouveau mot de passe", "settings": [] }
{% endschema %}
